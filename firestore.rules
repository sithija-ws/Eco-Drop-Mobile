rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    function isCollector() {
      return isAuthenticated() && getUserData().role == 'collector';
    }

    function isResident() {
      return isAuthenticated() && getUserData().role == 'resident';
    }

    // 1. Users collection
    match /users/{userId} {
      allow create: if isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.role in ["resident", "collector"]
        && request.resource.data.uid == request.auth.uid;

      allow read: if isAuthenticated();

      allow update: if isAuthenticated()
        && (
          (
            request.auth.uid == userId
            && request.resource.data.role == resource.data.role
            && request.resource.data.uid == resource.data.uid
          )
          || (
            resource.data.role == "collector"
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["rating", "reviewCount", "updatedAt"])
          )
          || isAdmin()
        );

      allow delete: if isAdmin();
    }

    // 2. Pickup Requests collection
    match /pickupRequests/{requestId} {
      allow create: if isResident()
        && request.resource.data.residentId == request.auth.uid
        && request.resource.data.status == "submitted";

      allow read: if isAuthenticated();

      allow update: if isAuthenticated()
        && (
          isAdmin()
          || (
            isResident()
            && resource.data.residentId == request.auth.uid
            && request.resource.data.residentId == resource.data.residentId
          )
          || (
            isCollector()
          )
        );

      allow delete: if isAdmin();
    }

    // 3. Collector Live GPS Locations
    match /collectorLiveLocations/{collectorId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && (request.auth.uid == collectorId || isCollector() || isAdmin());
    }

    // 4. Smart Bins collection
    match /smartBins/{binId} {
      allow read: if isAuthenticated();
      allow write: if isCollector() || isAdmin();
    }

    // 5. Waste Reports collection
    match /wasteReports/{reportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || (resource.data.reporterId == request.auth.uid);
    }

    // 6. Collection Schedules
    match /collectionSchedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 7. Reward Items Catalog
    match /rewardItems/{rewardId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // 8. User Rewards & Voucher Claim History
    match /userRewards/{userRewardId} {
      allow read: if isAuthenticated();
      allow create: if isResident() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (resource.data.userId == request.auth.uid);
    }

    // Default catch-all rule (for development flexibility)
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
